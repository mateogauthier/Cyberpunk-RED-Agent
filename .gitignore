# .gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Virtual environments
venv/
env/

# IDE/Editor specific files
.idea/
.vscode/
*.swp

# Env files
.env
*.env

# Lore files — keep the folder tracked but not its contents (copyright)
lore/*
!lore/.gitkeep

# Lore index cache (auto-generated from lore/)
.lore_cache.pkl

# SQLite database (runtime data)
data/
